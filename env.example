# ============================================================
# Vincula Tu Mente — Variables de entorno
# ============================================================
# Copia este archivo como .env.local y rellena los valores.
# NUNCA subas .env.local a git (ya está en .gitignore).
# ============================================================

# --- KEYSTATIC CLOUD (producción) ---------------------------
# Obtenidos en https://keystatic.cloud tras crear el proyecto.

KEYSTATIC_STORAGE_KIND=cloud
KEYSTATIC_CLOUD_PROJECT=tu-equipo/vinculatumente

# --- DESARROLLO LOCAL ---------------------------------------
# En desarrollo no hace falta nada: Keystatic usa storage local
# y escribe directamente en src/content/posts/.
